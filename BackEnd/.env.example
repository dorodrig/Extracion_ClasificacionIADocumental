# ============================================================
# GRM Backend — Variables de Entorno
# Copiar como .env y completar con valores reales
# NUNCA commitear el archivo .env a Git
# ============================================================

# Base de Datos (SQL Server)
DATABASE_URL=mssql+pyodbc://sa:YourPassword@localhost\SQLEXPRESS:1433/GRM_DB?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

# Seguridad (JWT)
SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Google Gemini (HU-04, HU-05)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
GEMINI_TIMEOUT_SECONDS=30
GEMINI_MAX_RETRIES=3

# AWS Textract (HU-03 — futuro)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# Celery (futuro)
# CELERY_BROKER_URL=redis://localhost:6379/0

# Storage
# STORAGE_BASE_PATH=C:\zData\GRM_Storage
