# Variables de entorno — GRM Backend
# CERO credenciales hardcodeadas (Gobernanza §3.4)
# Copiar este archivo como .env y completar los valores reales.
# NUNCA commitear el archivo .env real a Git.

# ── Base de datos SQL Server ──────────────────────────────────────────────────
DATABASE_URL=mssql+pyodbc://sa:TU_PASSWORD@localhost\\SQLEXPRESS/GRM_DB?driver=ODBC+Driver+17+for+SQL+Server

# ── Seguridad JWT ─────────────────────────────────────────────────────────────
SECRET_KEY=cambia_esto_por_una_clave_aleatoria_segura
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=TU_GEMINI_API_KEY

# ── AWS Textract ──────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=TU_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=TU_AWS_SECRET_KEY
AWS_DEFAULT_REGION=us-east-1
